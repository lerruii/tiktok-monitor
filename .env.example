# Copia este archivo a ".env" y rellena los valores desde
# https://developers.tiktok.com/apps -> tu app -> "Login Kit"

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Debe coincidir EXACTAMENTE con el "Redirect URI" configurado en el portal de TikTok
TIKTOK_REDIRECT_URI=http://localhost:8787/callback

# Puerto local que usa auth/authorize.mjs para recibir el callback de TikTok
AUTH_SERVER_PORT=8787
